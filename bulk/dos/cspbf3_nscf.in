&CONTROL
    calculation = 'nscf',
    prefix = 'cspbf3',
    outdir = '../../tmp/',
    pseudo_dir = '../../pseudo/',
/

&SYSTEM
    ibrav = 1,
    celldm(1) = 9.27293,
    nat = 5,
    ntyp = 3,
    ecutwfc = 80,
    ecutrho = 640,
    occupations = 'fixed',
    nbnd = 40,
/

&ELECTRONS
    conv_thr = 1.0d-8,
    mixing_beta = 0.3,
/

ATOMIC_SPECIES
Cs 132.91 Cs.pbe-spn-kjpaw_psl.1.0.0.UPF
Pb 207.2 Pb.pbe-dn-kjpaw_psl.1.0.0.UPF
F 18.998 F.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS crystal
Pb 0.000000 0.000000 0.000000
Cs 0.500000 0.500000 0.500000
F  0.000000 0.500000 0.000000
F  0.500000 0.000000 0.000000
F  0.000000 0.000000 0.500000

K_POINTS automatic
12 12 12 0 0 0
