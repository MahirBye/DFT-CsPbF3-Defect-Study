&CONTROL
    calculation = 'scf',
    prefix = 'cspbf3_VF',
    outdir = '../../tmp/',
    pseudo_dir = '../../pseudo/',
/

&SYSTEM
    ibrav = 1,
    celldm(1) = 18.547,
    nat = 39,
    ntyp = 3,
    ecutwfc = 80,
    ecutrho = 640,
    occupations = 'smearing',
    smearing = 'gaussian',
    degauss = 0.03,
/

&ELECTRONS
    conv_thr = 1.0d-6,
    mixing_beta = 0.05,
    electron_maxstep = 200,
    diagonalization = 'david',
/

